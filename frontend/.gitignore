# ══════════════════════════════════════════
# HoraCerta — .gitignore
# ══════════════════════════════════════════

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ── Virtualenv ──
venv/
.venv/
env/

# ── Ambiente ──
.env
.env.local
.env.production

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Testes / Lint ──
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ── Celery ──
celerybeat-schedule
celerybeat-schedule-shm
celerybeat-schedule-wal
celerybeat.pid

# ── Node / Frontend ──
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ── Banco local ──
*.sqlite3
*.db

# ── Logs ──
*.log
logs/