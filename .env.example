# ══════════════════════════════════════════
# HoraCerta — Variáveis de Ambiente
# Copie para .env e preencha os valores
# ══════════════════════════════════════════

# ── Banco de Dados ──
DATABASE_URL=postgresql://horacerta:horacerta123@localhost:5433/horacerta

# ── JWT ──
SECRET_KEY=TROQUE-ESTA-CHAVE-EM-PRODUCAO
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Redis (Celery) ──
REDIS_URL=redis://localhost:6379/0

# ── Email (SMTP) ──
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

# ── WhatsApp (Evolution API) ──
# Ativar quando tiver servidor Evolution rodando
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
